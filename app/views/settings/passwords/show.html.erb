<h1>Alterar Senha</h1>

<%= form_with(model: @user, url: settings_password_path, method: :patch, local: true) do |form| %>
  <% if @user.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h2><%= pluralize(@user.errors.count, "erro") %> impediu sua senha de ser alterada:</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :current_password, "Senha Atual", class: "form-label" %>
    <%= form.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
    <small class="form-text text-muted">Precisamos da sua senha atual para confirmar as alterações.</small>
  </div>

  <div class="mb-3">
    <%= form.label :password, "Nova Senha", class: "form-label" %>
    <%= form.password_field :password, autocomplete: "new-password", class: "form-control" %>
    <% if @minimum_password_length %>
      <small class="form-text text-muted"><%= @minimum_password_length %> caracteres no mínimo.</small>
    <% end %>
  </div>

  <div class="mb-3">
    <%= form.label :password_confirmation, "Confirme a Nova Senha", class: "form-label" %>
    <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
  </div>

  <div class="actions">
    <%= form.submit "Alterar Senha", class: "btn btn-primary" %>
  </div>
<% end %>

<hr>
<%= link_to "Voltar para o Perfil", settings_profile_path, class: "btn btn-light mt-2" %>

