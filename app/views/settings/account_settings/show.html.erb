<h1>Configurações da Conta</h1>

<%= form_with(model: @user, url: settings_account_path, method: :patch, local: true) do |form| %>
  <% if @user.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h2><%= pluralize(@user.errors.count, "erro") %> impediu estas configurações de serem salvas:</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :language, "Idioma", class: "form-label" %>
    <%= form.select :language, options_for_select([["Português (Brasil)", "pt-BR"], ["Inglês", "en"]], @user.language), {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :time_zone, "Fuso Horário", class: "form-label" %>
    <%= form.time_zone_select :time_zone, nil, { default: @user.time_zone || "Brasilia" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :currency, "Moeda Padrão", class: "form-label" %>
    <%= form.select :currency, options_for_select([["Real Brasileiro (BRL)", "BRL"], ["Dólar Americano (USD)", "USD"], ["Euro (EUR)", "EUR"]], @user.currency), {}, class: "form-select" %>
  </div>

  <div class="actions">
    <%= form.submit "Salvar Configurações da Conta", class: "btn btn-primary" %>
  </div>
<% end %>

<hr>
<%= link_to "Voltar para o Perfil", settings_profile_path, class: "btn btn-light mt-2" %>

