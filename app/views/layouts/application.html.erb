<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for(:title) || "Grana Livre | AdminLTE 3" %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Google Font: Source Sans Pro -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <!-- Font Awesome -->
  <%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css", media: "all", "data-turbo-track": "reload" %>
  <!-- Theme style -->
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

  <%= yield :head %>
</head>
<body class="hold-transition sidebar-mini layout-fixed">
<div class="wrapper">

  <%# Preloader %>
  <%# <div class="preloader flex-column justify-content-center align-items-center"> %>
    <%# <img class="animation__shake" src="<%= asset_path("AdminLTELogo.png") %>" alt="AdminLTELogo" height="60" width="60"> %>
  <%# </div> %>

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <!-- Left navbar links -->
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
      </li>
      <li class="nav-item d-none d-sm-inline-block">
        <a href="<%= root_path %>" class="nav-link">Home</a>
      </li>
    </ul>

    <!-- Right navbar links -->
    <ul class="navbar-nav ml-auto">
      <!-- User Dropdown Menu -->
      <% if user_signed_in? %>
        <li class="nav-item dropdown">
          <a class="nav-link" data-toggle="dropdown" href="#">
            <i class="far fa-user"></i> <%= current_user.email %>
          </a>
          <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
            <%= link_to "Perfil", settings_profile_path, class: "dropdown-item" %>
            <div class="dropdown-divider"></div>
            <%= link_to "Sair", destroy_user_session_path, method: :delete, class: "dropdown-item", data: { turbo_method: :delete } %>
          </div>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to "Login", new_user_session_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Registrar", new_user_registration_path, class: "nav-link" %>
        </li>
      <% end %>
      <li class="nav-item">
        <a class="nav-link" data-widget="fullscreen" href="#" role="button">
          <i class="fas fa-expand-arrows-alt"></i>
        </a>
      </li>
    </ul>
  </nav>
  <!-- /.navbar -->

  <!-- Main Sidebar Container -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4">
    <!-- Brand Logo -->
    <a href="<%= root_path %>" class="brand-link">
      <img src="<%= asset_path("AdminLTELogo.png") %>" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
      <span class="brand-text font-weight-light">Grana Livre</span>
    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar user panel (optional) -->
      <% if user_signed_in? %>
        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
          <div class="image">
            <%# <img src="dist/img/user2-160x160.jpg" class="img-circle elevation-2" alt="User Image"> %>
            <i class="fas fa-user-circle fa-2x text-light"></i>
          </div>
          <div class="info">
            <a href="#" class="d-block"><%= current_user.email %></a>
          </div>
        </div>
      <% end %>

      <!-- Sidebar Menu -->
      <nav class="mt-2">
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
          <li class="nav-item">
            <%= link_to dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path)}" do %>
              <i class="nav-icon fas fa-tachometer-alt"></i>
              <p>Dashboard</p>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to transactions_path, class: "nav-link #{'active' if controller_name == 'transactions'}" do %>
              <i class="nav-icon fas fa-exchange-alt"></i>
              <p>Transações</p>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to accounts_path, class: "nav-link #{'active' if controller_name == 'accounts'}" do %>
              <i class="nav-icon fas fa-wallet"></i>
              <p>Contas</p>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to categories_path, class: "nav-link #{'active' if controller_name == 'categories'}" do %>
              <i class="nav-icon fas fa-tags"></i>
              <p>Categorias</p>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to calendar_path, class: "nav-link #{'active' if current_page?(calendar_path)}" do %>
              <i class="nav-icon far fa-calendar-alt"></i>
              <p>Calendário</p>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to reports_path, class: "nav-link #{'active' if controller_name == 'reports'}" do %>
              <i class="nav-icon fas fa-chart-pie"></i>
              <p>Relatórios</p>
            <% end %>
          </li>
          <li class="nav-item #{'menu-open' if controller_path.start_with?('settings')}">
            <a href="#" class="nav-link #{'active' if controller_path.start_with?('settings')}">
              <i class="nav-icon fas fa-cog"></i>
              <p>
                Configurações
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <%= link_to settings_profile_path, class: "nav-link #{'active' if current_page?(settings_profile_path)}" do %>
                  <i class="far fa-circle nav-icon"></i>
                  <p>Perfil</p>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to settings_password_path, class: "nav-link #{'active' if current_page?(settings_password_path)}" do %>
                  <i class="far fa-circle nav-icon"></i>
                  <p>Alterar Senha</p>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to settings_account_setting_path, class: "nav-link #{'active' if current_page?(settings_account_setting_path)}" do %>
                  <i class="far fa-circle nav-icon"></i>
                  <p>Conta</p>
                <% end %>
              </li>
               <li class="nav-item">
                <%= link_to settings_notification_preference_path, class: "nav-link #{'active' if current_page?(settings_notification_preference_path)}" do %>
                  <i class="far fa-circle nav-icon"></i>
                  <p>Notificações</p>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to settings_backup_path, class: "nav-link #{'active' if current_page?(settings_backup_path)}" do %>
                  <i class="far fa-circle nav-icon"></i>
                  <p>Backup</p>
                <% end %>
              </li>
            </ul>
          </li>
        </ul>
      </nav>
      <!-- /.sidebar-menu -->
    </div>
    <!-- /.sidebar -->
  </aside>

  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0"><%= content_for(:page_title) || "Página" %></h1>
          </div><!-- /.col -->
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
              <li class="breadcrumb-item"><a href="<%= root_path %>">Home</a></li>
              <li class="breadcrumb-item active"><%= content_for(:page_title) || "Página" %></li>
            </ol>
          </div><!-- /.col -->
        </div><!-- /.row -->
      </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->

    <!-- Main content -->
    <section class="content">
      <div class="container-fluid">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
        <% end %>
        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
        <% end %>
        <%= yield %>
      </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
  </div>
  <!-- /.content-wrapper -->
  <footer class="main-footer">
    <strong>Copyright &copy; 2024-<%= Time.now.year %> <a href="#">Grana Livre</a>.</strong>
    All rights reserved.
    <div class="float-right d-none d-sm-inline-block">
      <b>Version</b> 1.0.0
    </div>
  </footer>

  <!-- Control Sidebar -->
  <aside class="control-sidebar control-sidebar-dark">
    <!-- Control sidebar content goes here -->
  </aside>
  <!-- /.control-sidebar -->
</div>
<!-- ./wrapper -->

</body>
</html>

