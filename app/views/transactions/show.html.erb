<p>
  <strong>Descrição:</strong>
  <%= @transaction.description %>
</p>

<p>
  <strong>Valor:</strong>
  <span style="color: <%= @transaction.transaction_type == 'income' ? 'green' : 'red' %>;">
    <%= number_to_currency(@transaction.amount) %>
  </span>
</p>

<p>
  <strong>Data:</strong>
  <%= @transaction.transaction_date.strftime("%d/%m/%Y") %>
</p>

<p>
  <strong>Tipo:</strong>
  <%= @transaction.transaction_type.capitalize %>
</p>

<p>
  <strong>Conta:</strong>
  <%= @transaction.account&.name %>
</p>

<p>
  <strong>Categoria:</strong>
  <%= @transaction.category&.name %>
</p>

<% if @transaction.notes.present? %>
  <p>
    <strong>Notas:</strong>
    <%= @transaction.notes %>
  </p>
<% end %>

<% if @transaction.transaction_type == "expense" %>
  <p>
    <strong>Paga:</strong>
    <%= @transaction.paid? ? "Sim" : "Não" %>
  </p>
<% end %>


<%= link_to "Editar", edit_transaction_path(@transaction), class: "btn btn-secondary" %> |
<%= link_to "Voltar para Transações", transactions_path, class: "btn btn-light" %>

