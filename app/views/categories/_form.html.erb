<%= form_with(model: category, local: true) do |form| %>
  <% if category.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h2><%= pluralize(category.errors.count, "erro") %> impediu esta categoria de ser salva:</h2>
      <ul>
        <% category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Nome da Categoria", class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :category_type, "Tipo", class: "form-label" %><br>
    <%= form.radio_button :category_type, "expense", checked: category.category_type == "expense" || category.category_type.blank? %> <%= form.label :category_type_expense, "Despesa" %>
    <%= form.radio_button :category_type, "income" %> <%= form.label :category_type_income, "Receita" %>
  </div>

  <div class="mb-3">
    <%= form.label :parent_id, "Categoria Pai (opcional)", class: "form-label" %>
    <%= form.collection_select :parent_id, @parent_categories, :id, :name, { include_blank: "Nenhuma (Categoria Principal)" }, class: "form-select" %>
    <small class="form-text text-muted">Selecione uma categoria pai para criar uma subcategoria.</small>
  </div>

  <div class="actions">
    <%= form.submit "Salvar Categoria", class: "btn btn-primary" %>
  </div>
<% end %>

