<h1>Contas</h1>

<%= link_to "Nova Conta", new_account_path, class: "btn btn-primary mb-3" %>
<%#= link_to "Realizar Transferência", new_transfer_accounts_path, class: "btn btn-info mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Nome da Conta</th>
      <th>Saldo Inicial</th>
      <th>Saldo Atual</th>
      <th>Incluir em Relatórios?</th>
      <th>Permitir Saldo Negativo?</th>
      <th colspan="3">Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @accounts.each do |account| %>
      <tr>
        <td><%= account.name %></td>
        <td><%= number_to_currency(account.initial_amount) %></td>
        <td><%= number_to_currency(account.current_amount) %></td>
        <td><%= account.include_in_reports? ? "Sim" : "Não" %></td>
        <td><%= account.allow_negative_amount? ? "Sim" : "Não" %></td>
        <td><%= link_to "Ver", account %></td>
        <td><%= link_to "Editar", edit_account_path(account) %></td>
        <td><%= link_to "Excluir", account, data: { turbo_method: :delete, turbo_confirm: "Tem certeza? Excluir uma conta também excluirá todas as transações associadas." } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

